# Copy these values into Render.
# Do not commit real .env files.

NODE_ENV=production
PORT=10000
# Set both secrets in Render's secret manager. Production rejects missing,
# documented-placeholder, and shorter-than-32-character values.
ADMIN_TOKEN=
CONTENT_API_REQUIRED=true
CONTENT_API_URL=
CONTENT_API_TOKEN=
CONTENT_API_TIMEOUT_MS=10000
CONTENT_API_MAX_BYTES=5242880
CONTENT_API_REFRESH_INTERVAL_MS=300000
# Set PLAYER_JOIN_SECRET in Render's secret manager, not in this file. Production
# rejects documented placeholders and values shorter than 32 UTF-8 bytes.
PLAYER_JOIN_SECRET=
ACCOUNT_IDENTITY_ENABLED=false
# Set the same 32+ byte random value in the Hostinger Next.js server and Render.
# It must differ from PLAYER_JOIN_SECRET. Never expose it as NEXT_PUBLIC_* or
# bundle it in the Android application.
ACCOUNT_IDENTITY_SECRET=
ACCOUNT_IDENTITY_ISSUER=apologia-ui
ACCOUNT_IDENTITY_ASSERTION_TTL_SECONDS=120
ACCOUNT_IDENTITY_CLOCK_SKEW_SECONDS=15
RATE_LIMIT_IDENTITY_EXCHANGE_MAX=6000
RATE_LIMIT_IDENTITY_EXCHANGE_WINDOW_MS=600000
QUIZ_AUTO_START=true
QUIZ_CONTINUOUS=true
CORS_ORIGINS=https://sandybrown-bear-488955.hostingersite.com
ALLOW_LOCAL_ORIGINS=false
RATE_LIMIT_REGISTER_MAX=120
RATE_LIMIT_REGISTER_WINDOW_MS=600000

DATABASE_URL=postgresql://user:password@host:5432/database
STATE_PERSISTENCE_DRIVER=postgres

YOUTUBE_API_KEY=
YOUTUBE_VIDEO_ID=
