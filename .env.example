# Admin authentication
ADMIN_TOKEN=your-secret-admin-token

# HMAC secret used to prove a player joined a specific room.
# Required in production. Generate at least 32 random bytes and keep it out of source control.
# Example generator: node -e "console.log(require('node:crypto').randomBytes(32).toString('base64url'))"
# Leave blank in local development to use the non-production fallback.
PLAYER_JOIN_SECRET=
# PLAYER_JOIN_TOKEN_TTL_SECONDS=21600

# Optional account-linked identities. Keep disabled until the Next.js server
# implements docs/ACCOUNT_IDENTITY_ROLLOUT.md. This secret is backend-only and
# must be different from PLAYER_JOIN_SECRET.
ACCOUNT_IDENTITY_ENABLED=false
ACCOUNT_IDENTITY_SECRET=
ACCOUNT_IDENTITY_ISSUER=apologia-ui
ACCOUNT_IDENTITY_ASSERTION_TTL_SECONDS=120
ACCOUNT_IDENTITY_CLOCK_SKEW_SECONDS=15
# Coarse shared-server ceiling: all authenticated exchanges may arrive from
# the same Next.js/Hostinger egress IP. Keep this well above room capacity.
RATE_LIMIT_IDENTITY_EXCHANGE_MAX=6000
RATE_LIMIT_IDENTITY_EXCHANGE_WINDOW_MS=600000

# Production runtime policy. Continuous mode also implies auto-start, resumes
# every active room after a restart, and loops the full topic series.
QUIZ_AUTO_START=true
QUIZ_CONTINUOUS=true

# Shared limit for all player-registration route aliases. The default allows
# a large classroom to join behind one public IP while retaining abuse protection.
RATE_LIMIT_REGISTER_MAX=120
RATE_LIMIT_REGISTER_WINDOW_MS=600000

# YouTube Live Chat Integration
YOUTUBE_API_KEY=your-youtube-api-key
# YOUTUBE_VIDEO_ID=your-live-video-id
# YOUTUBE_LIVECHAT_ID=optional-direct-chat-id

# Quiz timing (seconds)
OPEN_SECONDS=25
LOCK_SECONDS=2
REVEAL_SECONDS=12

# Scoring mode
# SCORING_MODE=v2   # v2 = base + difficulty + streak, with time multiplier
# SCORING_MODE=flat # flat = +10 per correct answer

# Server
PORT=4000

# CORS (comma-separated browser origins; ALLOWED_ORIGIN remains a compatibility alias)
CORS_ORIGINS=http://localhost:3000
# ALLOW_LOCAL_ORIGINS=false

# Runtime persistence. Render supplies DATABASE_URL from managed PostgreSQL.
# DATABASE_URL=postgresql://user:password@host:5432/database
# STATE_PERSISTENCE_DRIVER=postgres

# GitHub Content Persistence (optional)
# Required for committing imported questions and startup sync
# GITHUB_OWNER=your-github-username
# GITHUB_REPO=apologia_sancta
# GITHUB_BRANCH=main
# GITHUB_TOKEN=ghp_your-fine-grained-pat
# CONTENT_ROOT=apologiasancta-ui/content/topics
#
# Optional aliases used by startup sync (falls back to the vars above)
# GITHUB_CONTENT_OWNER=your-github-username
# GITHUB_CONTENT_REPO=apologia_sancta
# GITHUB_CONTENT_BRANCH=main
# GITHUB_CONTENT_PATH=apologiasancta-ui/content/topics
