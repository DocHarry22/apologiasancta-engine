# Admin authentication
ADMIN_TOKEN=your-secret-admin-token

# YouTube Live Chat Integration
YOUTUBE_API_KEY=your-youtube-api-key
# YOUTUBE_VIDEO_ID=your-live-video-id
# YOUTUBE_LIVECHAT_ID=optional-direct-chat-id

# Quiz timing (seconds)
OPEN_SECONDS=25
LOCK_SECONDS=2
REVEAL_SECONDS=12

# Server
PORT=4000

# CORS (comma-separated list of allowed origins)
# ALLOWED_ORIGIN=https://your-ui-domain.com

# GitHub Content Persistence (optional)
# Required for committing imported questions to the UI repo
# GITHUB_OWNER=your-github-username
# GITHUB_REPO=apologiasancta-ui
# GITHUB_BRANCH=main
# GITHUB_TOKEN=ghp_your-fine-grained-pat
# CONTENT_ROOT=content/topics
